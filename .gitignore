# Data files (large, from DataSUS)
R_analysis/data/raw/*.dbc
R_analysis/data/raw/*.DBC
R_analysis/data/raw/*.xlsx
R_analysis/data/processed/*.rds

# R environment
.Rhistory
.RData
.Rproj.user/
*.Rproj

# OS files
.DS_Store
Thumbs.db
~$*

# Output (regenerable from code)
R_analysis/output/figures/*.png
R_analysis/output/maps/*.png
R_analysis/output/supplementary/*.png

# Keep PDFs and Excel outputs
!R_analysis/output/**/*.pdf
!R_analysis/output/**/*.xlsx
!R_analysis/output/**/*.txt
